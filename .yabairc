#!/usr/bin/env sh

# global settings
yabai -m config window_placement             second_child
yabai -m config window_topmost               off
yabai -m config window_border                on
yabai -m config window_border_placement      exterior 
yabai -m config window_border_width          4
yabai -m config active_window_border_color   0x55000000
yabai -m config normal_window_border_color   0x11000000
yabai -m config insert_window_border_color   0xffd75f5f
yabai -m config split_ratio                  0.50
yabai -m config auto_balance                 off

# general space settings
yabai -m config layout                       bsp
yabai -m config top_padding                  20
yabai -m config bottom_padding               20
yabai -m config left_padding                 20
yabai -m config right_padding                20
yabai -m config window_gap                   10

# rules
yabai -m rule --add app="iTerm2" title="Hotkey Window" manage=off border=off
yabai -m rule --add app="Cumulus" manage=off border=off
