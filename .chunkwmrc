#!/bin/bash

chunkc core::plugin_dir ~/.chunkwm_plugins
chunkc core::hotload 1

#
# NOTE: The following are config variables for the chunkwm-tiling plugin
#

chunkc set global_desktop_mode           bsp

chunkc set global_desktop_offset_top     20
chunkc set global_desktop_offset_bottom  20
chunkc set global_desktop_offset_left    20
chunkc set global_desktop_offset_right   20
# chunkc set global_desktop_offset_gap     20

chunkc set desktop_padding_step_size     10
chunkc set desktop_gap_step_size         5

chunkc set bsp_spawn_left                1
chunkc set bsp_optimal_ratio             1.618
chunkc set bsp_split_mode                optimal
chunkc set bsp_split_ratio               0.5

chunkc set window_focus_cycle            monitor
chunkc set mouse_follows_focus           0
chunkc set window_float_next             0
chunkc set window_float_center           1
chunkc set window_region_locked          1

#
# NOTE: The following are config variables for the chunkwm-border plugin
#

#chunkc set focused_border_color          0x8A000000
chunkc set focused_border_color          0xFF3175EB
chunkc set focused_border_width          10
chunkc set focused_border_radius         10
chunkc set focused_border_outline        1
chunkc set focused_border_skip_floating  1

chunkc set preselect_border_color        0xfffeb94e
chunkc set preselect_border_width        10
chunkc set preselect_border_radius       4

#
# NOTE: specify plugins to load when chunkwm starts.
#       if chunkc plugin_dir is not set, the absolutepath is necessary.
#

chunkc core::load tiling.so
chunkc core::load border.so

#
# NOTE: shell commands require escaped quotes
#       to pass value containing a whitespace.
#

chunkc tiling::rule --owner Finder --name Copy --state float
chunkc tiling::rule --owner iTerm2 --name Hotkey Window --state float
chunkc tiling::rule --owner IntelliJ --state float
chunkc tiling::rule --owner Illustrator CC --state float
chunkc tiling::rule --owner scrcpy --state float
# chunkc tiling::rule --owner qemu-system-x86_64 --state float
# chunkc tiling::rule --owner qemu-system-i386 --state float

